# ============================================================
# ENVIRONMENT VARIABLES — Copy to .env and fill in values
# NEVER commit .env to version control
# ============================================================

# ── Application ─────────────────────────────────────────────
APP_VERSION=1.0.0
NODE_ENV=production
BUILD_DATE=

# ── Domain & Ports ──────────────────────────────────────────
DOMAIN=yourdomain.com
PORT=80
SSL_PORT=443
TZ=UTC

# ── Vite Build-time Variables (prefix: VITE_) ───────────────
VITE_APP_ENV=production
VITE_APP_VERSION=1.0.0
VITE_API_BASE_URL=https://api.yourdomain.com
VITE_SENTRY_DSN=

# ── Grafana ─────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme_strong_password_here

# ── Email / SMTP ─────────────────────────────────────────────
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM=noreply@yourdomain.com
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL=ops@yourdomain.com

# ── Secrets ─────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
SECRET_KEY=replace_with_strong_random_secret
JWT_SECRET=replace_with_strong_random_secret

# ── Registry (for CI/CD image push) ─────────────────────────
DOCKER_REGISTRY=ghcr.io
DOCKER_IMAGE_NAME=yourorg/devops-dashboard

# ============================================================
# .gitignore — Comprehensive
# ============================================================

# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
dist-ssr/
build/
out/
.output/

# Environment files (NEVER commit secrets)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# SSL certificates (mount via secrets manager)
ssl/
*.pem
*.crt
*.key
*.p12
*.pfx

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# Editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# TypeScript
*.tsbuildinfo

# Vite
vite.config.ts.timestamp-*

# Docker
.docker/

# Monitoring data (runtime volumes)
prometheus-data/
grafana-data/
loki-data/

# Test coverage
coverage/
.nyc_output/

# Temporary
tmp/
temp/
.cache/
